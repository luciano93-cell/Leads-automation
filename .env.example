# Lead-Automatisierung — Environment Variables
# Kopiere diese Datei nach `.env` und fülle die Werte aus.
# .env wird NIE committet (steht in .gitignore).

# ---- App ----
ENV=development           # development | staging | production
LOG_LEVEL=INFO
APP_BASE_URL=https://leads.firma.de
SECRET_KEY=replace-me-32+-random-bytes

# ---- Database ----
DATABASE_URL=sqlite:///./data/leads.sqlite

# ---- Anthropic / Claude ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Microsoft Graph ----
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=sales@firma.de
GRAPH_WEBHOOK_SECRET=replace-me        # client-state for validation
GRAPH_WEBHOOK_NOTIFICATION_URL=https://leads.firma.de/ingest/email

# ---- Salesforce ----
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login                         # login | test (für Sandbox: test)

# ---- Clay ----
CLAY_WEBHOOK_SECRET=replace-me          # HMAC shared secret

# ---- SMTP (Review-Mails) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=leads@firma.de
REVIEW_RECIPIENT=sales-review@firma.de

# ---- Backups ----
BACKUP_TARGET=                           # z.B. user@u123456.your-storagebox.de:/backups
